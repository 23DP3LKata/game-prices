APP_NAME="Game Prices"
# Environment: local|production|staging
APP_ENV=production
# Never enable debug in production
APP_KEY=
APP_DEBUG=false
# Use your HTTPS domain here
APP_URL=https://example.com
# Frontend entry point (used by CORS, etc.)
FRONTEND_URL=https://example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance driver: file or database
APP_MAINTENANCE_DRIVER=file

# PHP-FPM workers for the built-in CLI server (optional)
# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Logging: use info or warning in production
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Database (fill with your production DB credentials)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=game_prices
DB_USERNAME=game_user
DB_PASSWORD=StrongPassword

# Sessions: use database or redis in production
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Set to your domain to scope cookies correctly
SESSION_DOMAIN=example.com
# Use secure cookies when serving over HTTPS
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Cache store: database or redis recommended in production
CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

# Redis settings (if used)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (fill with your SMTP provider settings)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=smtp_user
MAIL_PASSWORD=smtp_password
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Vite: keep app name for frontend
VITE_APP_NAME="${APP_NAME}"

# ITAD API config (leave empty if not used)
ITAD_API_KEY=
ITAD_COUNTRY=DE
ITAD_SHOP_STEAM=61
ITAD_SHOP_EPIC=16

# Notes:
# 1) Copy this file to .env and fill secrets (APP_KEY, DB_PASSWORD, MAIL_PASSWORD, AWS keys).
# 2) Generate app key: `php artisan key:generate`.
# 3) Cache config/routes/views after edits: `php artisan config:cache && php artisan route:cache`.